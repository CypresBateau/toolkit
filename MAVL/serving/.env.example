# ── 必填 ─────────────────────────────────────────────────────────────────────
# checkpoint 容器内绝对路径
MAVL_MODEL_PATH=/workspace/MAVL/checkpoints/checkpoint_full_46.pth

# observation explanation.json 绝对路径（含空格，Python open() 直接支持）
MAVL_DISEASE_BOOK_PATH=/workspace/MAVL/Zero-shot_classification/observation explanation.json

# gpt4_mimic.json 绝对路径
MAVL_CONCEPT_BOOK_PATH=/workspace/MAVL/Pretrain/concept_gen/gpt4_mimic.json

# 本地 Bio_ClinicalBERT 快照路径（无需联网）
MAVL_TEXT_ENCODER=/root/.cache/huggingface/hub/models--emilyalsentzer--Bio_ClinicalBERT/snapshots/d5892b39a4adaed74b92212a44081509db72f87b

# ── 可选 ─────────────────────────────────────────────────────────────────────
MAVL_DEVICE=cuda
MAVL_INFERENCE_MODE=feature
MAX_FILE_SIZE_MB=20
